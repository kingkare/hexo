//- 以上为原版 以下为新版

if site.data.essay
  each i in site.data.essay
    #essay_page
      //- ============================================
      //- 区域 1: 顶部大图 (保持原样)
      //- ============================================
      - var essayTopBg = i.top_background ? String(i.top_background) : ""
      - var isVideoBg = essayTopBg.endsWith('.mp4')
      
      .author-content.author-content-item.essayPage.single(style = (essayTopBg && !isVideoBg) ? `background: url(${url_for(essayTopBg)}) left 28% / cover no-repeat;` : "")
        .card-content
          .author-content-item-tips=i.title
          span.author-content-item-title=i.subTitle
          .content-bottom
            .tips=i.tips
          .banner-button-group
            a.banner-button(href=url_for(i.avatarLink || '/about/'))
              i.anzhiyufont.anzhiyu-icon-arrow-circle-right
              span.banner-button-text=i.buttonText

      //- ============================================
      //- 区域 2: 顶部视频 (添加了强制防重叠样式)
      //- ============================================
      if i.top_video || isVideoBg
        - var videoSrc = i.top_video ? i.top_video : essayTopBg
        //- 核心修改：增加了 clear:both 和 margin-bottom，并设置为相对定位
        .essay-header-wrapper(style="width: 100%; display: block; clear: both; margin: 20px 0 20px 0; position: relative; z-index: 1;")
          div(style="width: 100%; border-radius: 12px; overflow: hidden; box-shadow: var(--anzhiyu-shadow-border); background: #000;")
            video#essay-header-video(autoplay loop muted playsinline webkit-playsinline style="width: 100%; height: auto; display: block; object-fit: cover; max-height: 450px;")
              source(src=url_for(videoSrc) type="video/mp4")
      
      //- ============================================
      //- 区域 3: 短文列表 (修复布局挤压)
      //- ============================================
      .desc(style="margin-bottom: 20px;")=i.desc
      
      //- 核心修改：在这里给 #bber 加了 style，强制 margin-top 为 0 或 20px，抵消主题默认的负边距
      #bber(style="margin-top: 20px !important; width: 100%; display: block;")
        section.timeline.page-1
          ul#waterfall.list
            each item, index in i.essay_list
              if index < i.limit
                li.bber-item
                  .bber-content
                    p.datacont= item.content
                    
                    //- 图片渲染
                    if item.image
                      .bber-container-img
                        each iten, indey in item.image
                          a.bber-content-img(href=url_for(item.image[indey]), target="_blank", data-fancybox="gallery", data-caption="")
                            img(src=url_for(item.image[indey]))
                        .bber-content-noimg
                        .bber-content-noimg
                        .bber-content-noimg
                    
                    //- 视频渲染
                    //- if item.video
                    //-   .bber-container-img
                    //-     each iten, indey in item.video  
                    //-       if (item.video[indey].includes('player.bilibili.com'))
                    //-         div(style="position: relative; padding: 30% 45%;margin-top: 10px;margin-bottom: 10px;")
                    //-           iframe(style="position: absolute; width: 100%; height: 100%; left: 0; top: 0;margin: 0;border-radius: 12px;border: var(--style-border);" src=url_for(item.video[indey]) scrolling="no" border="0" frameborder="no" framespacing="0" allowfullscreen="true")
                    //-       else
                    //-         a.bber-content-video(href=url_for(item.video[indey]) data-fancybox="gallery", data-caption="")
                    //-           video(src=url_for(item.video[indey]))
                    //-     .bber-content-noimg
                    //-     .bber-content-noimg
                    //-     .bber-content-noimg
                    //- 视频渲染 修改版 
                    //-使哔哩哔哩视频居中显示 width: 100%: 强制容器宽度占满整个卡片，消除左右两侧的留白，自然也就“居中”了。 padding-bottom: 75%: 这里我设置成了 4:3 的比例（或者你可以改成 56.25% 即 16:9）。B 站的外链播放器有时候上下会有黑边或控制条，稍微高一点的比例（75%）通常在手机和电脑上显示效果更好，不会切掉弹幕或控制栏。 position: absolute: 让 iframe 绝对定位于这个容器内，确保它乖乖填满我们设定好的盒子。
                    
                    if item.video
                      .bber-container-img
                        each iten, indey in item.video  
                          if (item.video[indey].includes('player.bilibili.com'))
                            //- 修改点：使用标准的 16:9 响应式容器写法
                            div(style="position: relative; width: 100%; height: 0; padding-bottom: 75%; margin: 10px 0; border-radius: 12px; overflow: hidden;")
                              iframe(style="position: absolute; width: 100%; height: 100%; left: 0; top: 0; border: 0;" src=url_for(item.video[indey]) scrolling="no" frameborder="no" framespacing="0" allowfullscreen="true")
                          else
                            a.bber-content-video(href=url_for(item.video[indey]) data-fancybox="gallery", data-caption="")
                              video(src=url_for(item.video[indey]))
                        .bber-content-noimg
                        .bber-content-noimg
                        .bber-content-noimg
                    
                    //- 音乐渲染
                    if item.aplayer
                      .bber-music
                        meting-js(id=item.aplayer.id, server=item.aplayer.server, type="song", mutex="true",preload="none", theme="var(--anzhiyu-main)", data-lrctype="0", order="list")
                    
                    hr
                    
                    //- 底部信息
                    .bber-bottom
                      .bber-info
                        .bber-info-time
                          - var datedata = new Date(item.date).toISOString()
                          i.anzhiyufont.anzhiyu-icon-clock
                          time.datatime(datetime= item.date)= datedata
                        if item.link 
                          a.bber-content-link(title="跳转到短文指引的链接", href=url_for(item.link), rel="external nofollow")
                            i.anzhiyufont.anzhiyu-icon-link
                            | 链接
                        if item.from
                          .bber-info-from
                            i.anzhiyufont.anzhiyu-icon-fw-fire
                            span=item.from
                        if item.address
                          .bber-info-from
                            i.anzhiyufont.anzhiyu-icon-location-dot
                            span=item.address
                      
                      .bber-reply(onclick=`rm.rightMenuCommentText('${item.content}')`)
                        i.anzhiyufont.anzhiyu-icon-message

      #bber-tips(style='color: var(--anzhiyu-secondtext);')
        ="- 只展示最近" + i.limit + "条短文 -"